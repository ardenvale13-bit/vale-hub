# Vale - Environment Configuration
# Copy to .env and fill in your values

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Single user mode (required) - your user UUID from Supabase
SINGLE_USER_ID=00000000-0000-0000-0000-000000000000

# API authentication key (required) - used by frontend and MCP clients
API_KEY=your-secret-api-key-here

# Server config
PORT=3000
NODE_ENV=development

# CORS - comma-separated origins (set your Vercel URL for production)
CORS_ORIGIN=http://localhost:5173

# ElevenLabs voice generation (optional)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_DEFAULT_VOICE_ID=your-voice-id

# OpenAI (optional, for future image generation)
OPENAI_API_KEY=your-openai-key
